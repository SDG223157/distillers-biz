# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/distillers?sslmode=require

# OpenAI (for distillation LLM)
OPENAI_API_KEY=sk-...

# SerpAPI (for research gathering)
SERPAPI_API_KEY=...

# Google OAuth (same project as watchinglist.app — add redirect URI in Cloud Console)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
AUTH_SECRET=...  # openssl rand -base64 32

# Restrict login to specific emails (comma-separated, empty = allow all)
ALLOWED_EMAILS=isky999@gmail.com

# App
NEXT_PUBLIC_APP_URL=https://distillers.biz
AUTH_URL=https://distillers.biz
